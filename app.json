{
  "expo": {
    "name": "voice-timer",
    "slug": "voice-timer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sechan.voicetimer",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "음성 명령으로 타이머를 제어하기 위해 마이크 접근이 필요합니다.",
        "NSSpeechRecognitionUsageDescription": "음성 인식을 통해 타이머 명령을 처리합니다."
      }
    },
    "android": {
      "package": "com.sechan.voicetimer",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-speech"
    ]
  }
}
